# ═══════════════════════════════════════════════════════════════
#  配置示例 —— 复制成 .env 后填写。带 ← SECRET 的绝不要提交进 git。
#  只有 TELEGRAM_BOT_TOKEN 是最低限度必填,其余都有合理默认或可选。
# ═══════════════════════════════════════════════════════════════

# ── 核心 / 网关 ──────────────────────────────────────────────
CHANNEL_PORT=3456                 # 主 HTTP + 客户端 WS 端口
CHANNEL_BRIDGE_PORT=3457          # 与 Claude Code(cc)之间的桥 WS(仅监听 127.0.0.1)
CHANNEL_PIN=                      # ← 可选:客户端鉴权 PIN。留空=不鉴权(仅限内网/反代后)
CHANNEL_TMUX=cc                   # cc 所在的 tmux 会话名
CHANNEL_USER=user                # 用户显示名(占位;prompts 里的名字见 personas/)
CHANNEL_ASSISTANT=assistant       # 主 AI 角色显示名

# ── Claude Code (cc) 后端 ────────────────────────────────────
CC_PROJECT_DIR=/path/to/your/cc/project   # cc 的工作目录(放 CLAUDE.md 人设的地方)
CLAUDE_BIN=/usr/bin/claude        # claude CLI 路径
STREAM_MODE=1                     # 1=经 cc 持久会话流式回复;0=仅一次性 spawn
STREAM_CHAT_TIMEOUT_MS=120000

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=               # ← SECRET 必填:主 AI 的 TG bot token(@BotFather)
ZHOUHENG_BOT_TOKEN=              # ← SECRET 可选:第二个 AI(co-persona)的独立 bot token
TG_MINIAPP_URL=https://your-domain.example   # 前端 PWA 的 HTTPS 地址(TG Mini App)
ADMIN_TG_IDS=                     # 运维命令(/restart /shutdown /logs)白名单,逗号分隔的 TG user id;留空=仅首个绑定的私聊

# ── 语音合成 TTS(可选,二选一或都配)────────────────────────
MINIMAX_API_KEY=                  # ← SECRET
MINIMAX_GROUP_ID=
MINIMAX_VOICE_ID=                 # 你自己克隆/挑选的音色 id
MINIMAX_MODEL=speech-01-turbo
MINIMAX_TTS_URL=
ELEVENLABS_API_KEY=               # ← SECRET
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
VOICE_PROB=0.15                   # 主动语音的概率

# ── 语音识别 STT(可选,处理用户语音消息)──────────────────
STT_API_KEY=                      # ← SECRET
STT_URL=
STT_MODEL=

# ── 视觉(可选,看图/看屏)────────────────────────────────────
VISION_API_KEY=                   # ← SECRET
VISION_URL=
VISION_MODEL=

# ── 备用 LLM(可选:群聊里的其他角色 / 副 persona)──────────
OPENAI_BASE=
OPENAI_API_KEY=                   # ← SECRET
OPENAI_MODEL=
GEMINI_BASE=
GEMINI_API_KEY=                   # ← SECRET
GEMINI_MODEL=
XAI_BASE=
XAI_API_KEY=                      # ← SECRET
XAI_MODEL=

# ── 推送(可选,iOS Bark)──────────────────────────────────────
BARK_KEY=                         # ← SECRET:你自己的 Bark 设备 key
BARK_TAP_URL=

# ── 音乐(可选,网易云)────────────────────────────────────────
NETEASE_COOKIE_FILE=              # ← 指向含 MUSIC_U cookie 的文件(SECRET,勿提交)

# ── 主动性 / 情感驱动引擎(行为调参,均可选)──────────────────
DESIRE_DRIVEN=1                   # 1=开启主动行为(主动找你/夜间内省);0=纯被动
SELF_DRIVE=1
COUPLING=0.5
BASELINE_DRIFT=0.02
ACT_THRESHOLD=0.6                 # 主动出声的阈值
PROACTIVE_DAILY_MAX=6             # 每天最多主动几次
NAG_COOLDOWN_MIN=90
SLEEP_LATEST=1                    # 深夜催睡窗口(小时)
WAKE=9                            # 早上唤醒点(小时)
EMOTION_TICK_INTERVAL_MS=9000000  # 情绪打点间隔(默认 2.5h)
DREAM_INTERVAL_DAYS=6             # 记忆整合"做梦"周期
